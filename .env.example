# Production Environment Variables
# Copy this to .env and update with your actual values

# Security
SECRET_KEY=your-super-secure-secret-key-here-change-this
DB_PASSWORD=your-secure-database-password-here

# Domain Configuration
DOMAIN_NAME=elliottacres.com
ADMIN_EMAIL=admin@elliottacres.com

# Database Configuration (for external services if needed)
POSTGRES_DB=elliott_acres
POSTGRES_USER=elliott_user

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False

# Optional: Backup Configuration
BACKUP_RETENTION_DAYS=7
BACKUP_S3_BUCKET=elliott-acres-backups

# Optional: Email Configuration (for contact forms)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Optional: Monitoring
SENTRY_DSN=your-sentry-dsn-here
